{
  "name": "reynahub-sys",
  "version": "2.0.0",
  "description": "REYNAHUB_SYS - Operating Hub & Workspace for operational tools and team productivity",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint src --ext .js",
    "format": "prettier --write \"src/**/*.{js,css,html}\"",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "coverage": "vitest run --coverage",
    "analyze": "vite build --mode analyze"
  },
  "keywords": [
    "reynahub",
    "operating-hub",
    "workspace",
    "productivity",
    "iframe-spa",
    "tool-aggregator"
  ],
  "author": "REYNAHUB Team",
  "license": "MIT",
  "devDependencies": {
    "vite": "^5.0.0",
    "terser": "^5.24.0",
    "eslint": "^8.55.0",
    "prettier": "^3.1.0",
    "vitest": "^1.0.0",
    "@vitest/ui": "^1.0.0",
    "@vitest/coverage-v8": "^1.0.0",
    "jsdom": "^23.0.0"
  },
  "dependencies": {},
  "engines": {
    "node": ">=18.0.0"
  },
  "browserslist": [
    "> 1%",
    "last 2 versions",
    "not dead",
    "not ie 11"
  ]
}